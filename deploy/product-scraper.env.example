# Secrets for the product-scraper TrueNAS app.
# Copy to /mnt/<pool>/apps/product-scraper/product-scraper.env on the NAS,
# fill in the values, then: chmod 600 product-scraper.env
# NEVER commit the filled-in copy.

# Tagged auth key from https://login.tailscale.com/admin/settings/keys
# (full key = ID + secret half, e.g. tskey-auth-kXXXXXXXCNTRL-XXXXXXXXXXXXXXX)
TS_AUTHKEY=

# Generate with: openssl rand -base64 48
DJANGO_SECRET_KEY=

# Optional: create an admin account on startup (for hosts without shell
# access). Remove or leave empty once the account exists.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional: Allegro REST API credentials — without them the four Allegro
# scrapers show a setup hint instead of results (DataDome blocks scraping).
# Register a (free) application at https://apps.developer.allegro.pl
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
